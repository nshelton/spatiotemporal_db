# Database connection
DATABASE_URL=postgresql://daruma:daruma_dev@localhost:5432/daruma

# API authentication
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here

# Optional: Server settings
HOST=0.0.0.0
PORT=8000

# Photo serving
# Root directory where photos are stored (same as --root-dir used during ingestion)
PHOTO_ROOT=D:/Photos
# Thumbnail cache directory (defaults to PHOTO_ROOT/.daruma_thumbs if not set)
# THUMB_CACHE_DIR=D:/Photos/.daruma_thumbs
# Max thumbnail dimension in pixels (default: 400)
# THUMB_SIZE=400
